DATABASE_URL=postgresql+asyncpg://lookout:lookout@db:5432/lookout
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:3000
INGEST_INTERVAL_HOURS=6

# Secret key for encrypting feed API tokens (generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FEED_SECRET_KEY=

# Optional: set to seed the database with mock data on startup if empty
SEED_ON_EMPTY=true

NEXT_PUBLIC_API_URL=http://localhost:8000
